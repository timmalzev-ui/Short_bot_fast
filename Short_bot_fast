# ================== API CACHE ==================
api_cache: Dict[str, Tuple[Any, float]] = {}
CACHE_TTL = 420

def get_cached(func, symbol: str) -> Any:
    key = f"{func.__name__}_{symbol}"
    now = time.time()
    if key in api_cache and now - api_cache[key][1] < CACHE_TTL:
        return api_cache[key][0]
    try:
        result = func(symbol)
        api_cache[key] = (result, now)
        return result
    except Exception as e:
        logger.warning(f"Cache miss {key}: {e}")
        return None if func.__name__ == "get_ticker" else 0.0

# ================== TELEGRAM ==================
def send_telegram_message(text: str) -> None:
    url = f"https://api.telegram.org/bot{BOT_TOKEN}/sendMessage"
    payload = {"chat_id": CHAT_ID, "text": text, "parse_mode": "Markdown"}
    for attempt in range(5):
        try:
            resp = requests.post(url, json=payload, timeout=15)
            if resp.status_code == 200:
                logger.info("✅ Telegram sent")
                return
            if resp.status_code == 429:
                time.sleep(2 ** attempt * 4)
        except Exception as e:
            logger.warning(f"Telegram attempt {attempt+1}/5: {e}")
        time.sleep(2 ** attempt * 1.8)
    logger.error("❌ Telegram failed after 5 attempts")

