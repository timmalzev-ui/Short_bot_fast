def get_6h_change(symbol: str) -> float:
    url = f"{BASE_URL}/v5/market/kline?category=linear&symbol={symbol}&interval=60&limit=7"
    try:
        resp = requests.get(url, timeout=10)
        resp.raise_for_status()
        data = resp.json()
        if data.get("retCode") != 0:
            logger.warning(f"Bybit вернул ошибку для {symbol}: {data.get('retMsg')}")
            return 0.0
        klines = data.get("result", {}).get("list", [])
        if len(klines) < 2:
            return 0.0
        price_old = float(klines[-1][4])
        price_now = float(klines[0][4])
        return (price_now - price_old) / price_old * 100
    except Exception as e:
        logger.warning(f"get_6h_change({symbol}) — пропущено: {type(e).__name__}")
        return 0.0

# ================== ИНДИКАТОРЫ FAST ==================
def calculate_roc(klines: List, periods: int) -> float:
    if len(klines) <= periods: return 0.0
    old = float(klines[periods][4])
    new = float(klines[0][4])
    return (new - old) / old * 100 if old > 0 else 0.0

def calculate_rsi(klines: List, period: int = 9) -> List[float]:
    if len(klines) < period + 1: return []
    closes = [float(k[4]) for k in klines]
    gains = [max(closes[i] - closes[i-1], 0) for i in range(1, len(closes))]
    losses = [max(closes[i-1] - closes[i], 0) for i in range(1, len(closes))]
    avg_gain = sum(gains[:period]) / period
    avg_loss = sum(losses[:period]) / period
    rsi = []
    for i in range(period, len(gains)):
        avg_gain = (avg_gain * (period - 1) + gains[i]) / period
        avg_loss = (avg_loss * (period - 1) + losses[i]) / period
        rs = avg_gain / avg_loss if avg_loss != 0 else 100
        rsi.append(100 - (100 / (1 + rs)))
    return rsi

def is_ultra_wick_rejection(klines: List) -> bool:
    if len(klines) < 5: return False
    o, h, l, c = map(float, [klines[0][1], klines[0][2], klines[0][3], klines[0][4]])
    body = abs(c - o)
    upper_wick = h - max(o, c)
    return upper_wick >= body * 3.8 and c < (o + l) / 2.2

def is_volume_climax(klines: List) -> bool:
    if len(klines) < 30: return False
    vols = [float(k[5]) for k in klines[:30]]
    return vols[0] >= sum(vols[5:]) / len(vols[5:]) * 2.8

def check_bearish_divergence(klines: List, cvd: float, rsi: List) -> bool:
    if len(klines) < 60 or len(rsi) < 4: return False
    highs = [i for i in range(5, len(klines)-5) if float(klines[i][2]) == max(float(k[2]) for k in klines[i-5:i+6])]
    if len(highs) < 3: return False
    return (float(klines[highs[-1]][4]) > float(klines[highs[-2]][4]) and
            rsi[-1] < rsi[-3] and cvd < 0)

def is_pump_mature(klines: List) -> bool:
    if len(klines) < 20: return False
    closes = [float(k[4]) for k in klines[:20]]
    max_price = max(closes)
    current = closes[0]
    return (max_price / min(closes) > 1.35 and current < max_price * 0.985)

# ================== CVD MANAGER ==================
class CVDManager:
    def __init__(self):
        self.url = "wss://stream.bybit.com/v5/public/linear"
        self.ws = None
        self.thread = None
        self._lock = threading.Lock()
        self.cvd: Dict[str, float] = {}
        self.prices: Dict[str, List[float]] = {}
        self.subscribed: set[str] = set()
        self._running = False

    def _on_message(self, ws, message: str):
        try:
            data = json.loads(message)
            if not data.get("topic", "").startswith("publicTrade."): return
            symbol = data["topic"].split(".")[1]
            for t in data.get("data", []):
                with self._lock:
                    delta = float(t["v"]) if t["S"] == "Buy" else -float(t["v"])
                    self.cvd[symbol] = self.cvd.get(symbol, 0.0) + delta
                    self.prices.setdefault(symbol, []).append(float(t["p"]))
                    if len(self.prices[symbol]) > 300:
                        self.prices[symbol] = self.prices[symbol][-300:]
        except:
            pass

    def _on_open(self, ws):
        logger.info("CVD WebSocket opened")
        self._resubscribe(ws)

    def _run(self):
        while self._running:
            self.ws = websocket.WebSocketApp(self.url, on_message=self._on_message, on_open=self._on_open)
            self.ws.run_forever(ping_interval=20)
            time.sleep(5)

    def start(self):
        if self._running: return
        self._running = True
        self.thread = threading.Thread(target=self._run, daemon=True)
        self.thread.start()

    def subscribe_symbol(self, symbol: str):
        with self._lock:
            if symbol in self.subscribed: return
            self.subscribed.add(symbol)
        if self.ws and self.ws.sock:
            self.ws.send(json.dumps({"op": "subscribe", "args": [f"publicTrade.{symbol}"]}))

    def _resubscribe(self, ws):
        with self._lock:
            if self.subscribed:
                ws.send(json.dumps({"op": "subscribe", "args": [f"publicTrade.{s}" for s in self.subscribed]}))

    def get_snapshot(self, symbol: str) -> Tuple[float, List[float]]:
        with self._lock:
            return self.cvd.get(symbol, 0.0), self.prices.get(symbol, [])

